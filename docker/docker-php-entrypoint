#!/bin/sh
set -e

# Check if jq is installed
if ! command -v jq >/dev/null 2>&1; then
    echo "ERROR: jq is required but not installed. Please install jq first." >&2
    exit 1
fi


# Function to check the availability of a database
check_db_availability() {
    local db_host="$1"
    local db_port="$2"
    echo "Waiting for $db_host:$db_port to be ready..."
    while ! nc -w 1 "$db_host" "$db_port" > /dev/null 2>&1; do
        # Show some progress
        echo -n '.'
        sleep 1
    done
    echo "\n\nGreat, $db_host is ready!"
}


# Set php.ini and .htaccess according to APPLICATION_ENV
if [ "$APPLICATION_ENV" = "development" ]; then
    cp "$PHP_INI_DIR/php.ini-development" "$PHP_INI_DIR/php.ini"
    sed -i 's|SetEnv APPLICATION_ENV "production"|SetEnv APPLICATION_ENV "development"|' /var/www/html/.htaccess
# else
#     cp "$PHP_INI_DIR/php.ini-production" "$PHP_INI_DIR/php.ini"
fi

# Configure database.ini using environment variables
{
  echo "user     = \"${MYSQL_USER:-}\""
  echo "password = \"${MYSQL_PASSWORD:-}\""
  echo "dbname   = \"${MYSQL_DATABASE:-}\""
  echo "host     = \"${MYSQL_HOST:-}\""
  echo "port     = \"${MYSQL_TCP_PORT:-3306}\""

  if [ -n "${MYSQL_UNIX_PORT:-}" ]; then
    echo "unix_socket = \"${MYSQL_UNIX_PORT}\""
  else
    echo ";unix_socket ="
  fi

  if [ -n "${MYSQL_LOG_PATH:-}" ]; then
    echo "log_path = ${MYSQL_LOG_PATH}"
  else
    echo ";log_path ="
  fi
} > /var/www/html/volume/config/database.ini

# Set permissions
chmod 600 /var/www/html/volume/config/database.ini
chown www-data:www-data /var/www/html/volume/config/database.ini

# Update OIDC configuration in local.config.php using environment variables
if [ -n "${OIDC_CLIENT_ID:-}" ] && [ -n "${OIDC_CLIENT_SECRET:-}" ]; then
  echo "Configuring OIDC settings..."
  # Escape special characters for sed
  ESCAPED_CLIENT_ID=$(echo "$OIDC_CLIENT_ID" | sed 's/[&/\]/\\&/g')
  ESCAPED_CLIENT_SECRET=$(echo "$OIDC_CLIENT_SECRET" | sed 's/[&/\]/\\&/g')

  sed -i "s|^\([[:space:]]*\)'client_id' => '.*'|\1'client_id' => '${ESCAPED_CLIENT_ID}'|" /var/www/html/volume/config/local.config.php
  sed -i "s|^\([[:space:]]*\)'client_secret' => '.*'|\1'client_secret' => '${ESCAPED_CLIENT_SECRET}'|" /var/www/html/volume/config/local.config.php

  chmod 600 /var/www/html/volume/config/local.config.php
  chown www-data:www-data /var/www/html/volume/config/local.config.php

  echo "OIDC configuration updated successfully."
else
  echo "OIDC environment variables not set. Skipping OIDC configuration."
fi

# Automatically download and install themes if provided
if [ -n "$OMEKA_THEMES" ]; then
  echo "Installing themes..."
  TMPDIR=$(mktemp -d)
  echo "$OMEKA_THEMES" | while read -r theme_url; do
    [ -z "$theme_url" ] && continue
    THEME_NAME=$(basename "$theme_url" .zip | sed 's/^theme-//')
    THEME_DIR="/var/www/html/volume/themes/$THEME_NAME"
    if [ -d "$THEME_DIR" ]; then
      echo "Theme '$THEME_NAME' already exists. Skipping."
      continue
    fi
    echo "Downloading theme from $theme_url"
    curl -sL "$theme_url" -o "$TMPDIR/theme.zip"
    unzip -oq "$TMPDIR/theme.zip" -d /var/www/html/volume/themes
  done
  rm -rf "$TMPDIR"
else
  echo "No theme URLs provided. Skipping theme installation."
fi

# Function to get download URL from GitLab repository URL
get_gitlab_zip_url() {
    repo_url="$1"
    # Normalize URL by removing trailing slashes
    normalized_url=$(echo "$repo_url" | sed 's|/*$||')

    # Extract owner and repo from URL and trim whitespace
    owner=$(echo "$normalized_url" | sed -n 's|https://gitlab.com/\([^/]*\)/\([^/]*\)$|\1|p' | tr -d '\n\r' | sed 's/^[[:space:]]*//;s/[[:space:]]*$//')
    repo=$(echo "$normalized_url" | sed -n 's|https://gitlab.com/\([^/]*\)/\([^/]*\)$|\2|p' | tr -d '\n\r' | sed 's/^[[:space:]]*//;s/[[:space:]]*$//')

    if [ -z "$owner" ] || [ -z "$repo" ]; then
        echo "ERROR: Invalid GitLab repository URL: $repo_url" >&2
        return 1
    fi

    # URL encode the owner/repo path
    encoded_path=$(echo "${owner}/${repo}" | sed 's|/|%2F|g')
    api_url="https://gitlab.com/api/v4/projects/${encoded_path}/releases"

    # Try to get the latest release
    latest_release=$(curl -s "$api_url" | jq -r '.[0]')

    if [ "$latest_release" != "null" ] && [ -n "$latest_release" ]; then
        # Get tag name from latest release
        tag_name=$(echo "$latest_release" | jq -r '.tag_name' | tr -d '\n\r' | sed 's/^[[:space:]]*//;s/[[:space:]]*$//')

        if [ -n "$tag_name" ] && [ "$tag_name" != "null" ]; then
            echo "https://gitlab.com/${owner}/${repo}/-/archive/${tag_name}/${repo}-${tag_name}.zip"
            return 0
        fi
    fi

    # No release found, fall back to the default branch
    echo "WARNING: No release found for $repo_url, using default branch" >&2
    echo "https://gitlab.com/${owner}/${repo}/-/archive/master/${repo}-master.zip"
    return 0
}

# Function to get download URL from GitHub repository URL
get_github_zip_url() {
    repo_url="$1"
    # Normalize URL by removing trailing slashes
    normalized_url=$(echo "$repo_url" | sed 's|/*$||')

    # Extract owner and repo from URL and trim whitespace
    owner=$(echo "$normalized_url" | sed -n 's|https://github.com/\([^/]*\)/\([^/]*\)$|\1|p' | tr -d '\n\r' | sed 's/^[[:space:]]*//;s/[[:space:]]*$//')
    repo=$(echo "$normalized_url" | sed -n 's|https://github.com/\([^/]*\)/\([^/]*\)$|\2|p' | tr -d '\n\r' | sed 's/^[[:space:]]*//;s/[[:space:]]*$//')

    if [ -z "$owner" ] || [ -z "$repo" ]; then
        echo "ERROR: Invalid GitHub repository URL: $repo_url" >&2
        return 1
    fi

    api_url="https://api.github.com/repos/${owner}/${repo}/releases/latest"

    # Try to get ZIP asset from release first (trim whitespace)
    download_url=$(curl -s "$api_url" | jq -r '.assets[] | select(.name | endswith(".zip")) | .browser_download_url' | head -n 1 | tr -d '\n\r' | sed 's/^[[:space:]]*//;s/[[:space:]]*$//')

    # Check if we got a valid download URL (not empty and not "null")
    if [ -n "$download_url" ] && [ "$download_url" != "null" ]; then
        echo "$download_url"
        return 0
    fi

    # No ZIP asset found, try to get the source code zipball from the latest release tag
    tag_name=$(curl -s "$api_url" | jq -r '.tag_name' | tr -d '\n\r' | sed 's/^[[:space:]]*//;s/[[:space:]]*$//')

    if [ -n "$tag_name" ] && [ "$tag_name" != "null" ]; then
        echo "https://github.com/${owner}/${repo}/archive/refs/tags/${tag_name}.zip"
        return 0
    fi

    # No release found, fall back to the default branch (usually main or master)
    echo "WARNING: No release found for $repo_url, using default branch" >&2
    echo "https://github.com/${owner}/${repo}/archive/refs/heads/main.zip"
    return 0
}

# Function to normalize module name from folder name
normalize_module_name() {
    folder_name="$1"

    # Remove common prefixes and suffixes using basic sed
    normalized="$folder_name"

    # Remove Omeka-S-module- prefix (case insensitive)
    normalized=$(echo "$normalized" | sed 's/^[Oo]meka-[Ss]-module-//')

    # Remove omeka-s-module- prefix (case insensitive)
    normalized=$(echo "$normalized" | sed 's/^omeka-s-module-//')

    # Remove -master suffix
    normalized=$(echo "$normalized" | sed 's/-master$//')

    # Remove -main suffix
    normalized=$(echo "$normalized" | sed 's/-main$//')

    # Remove version suffixes like -v1.2.3 or -1.2.3
    normalized=$(echo "$normalized" | sed 's/-v\?[0-9][0-9]*\.[0-9][0-9]*\.[0-9][0-9]*$//')
    normalized=$(echo "$normalized" | sed 's/-v\?[0-9][0-9]*\.[0-9][0-9]*$//')

    # Remove other common branch suffixes
    normalized=$(echo "$normalized" | sed 's/-develop$//')
    normalized=$(echo "$normalized" | sed 's/-dev$//')
    normalized=$(echo "$normalized" | sed 's/-stable$//')

    echo "$normalized"
}

# Function to process download URLs
process_download() {
    url="$1"
    type="$2"

    case "$url" in
        *.zip)
            # Direct ZIP link
            echo "$url"
            ;;
        https://github.com/*)
            # GitHub repository URL
            get_github_zip_url "$url"
            ;;
        https://gitlab.com/*)
            # GitLab repository URL
            get_gitlab_zip_url "$url"
            ;;
        *)
            echo "ERROR: Unsupported URL format for $type: $url" >&2
            return 1
            ;;
    esac
}

# Function to download, extract, and install a module from a URL (GitHub, GitLab, or direct zip)
install_module_from_url() {
    local name="$1"
    local url="$2"
    local modules_dir="/var/www/html/volume/modules"
    local tmpdir zip_url existing_dirs new_dir

    # Skip if the module directory already exists
    if [ -d "$modules_dir/$name" ]; then
        echo "Module '$name' already exists. Skipping."
        return 0
    fi

    # Resolve the actual ZIP download URL via the existing helper
    zip_url=$(process_download "$url" "module") || return 1
    if [ -z "$zip_url" ]; then
        echo "ERROR: Could not determine download URL for module '$name'" >&2
        return 1
    fi

    echo "Downloading module '$name' from $zip_url..."
    tmpdir=$(mktemp -d)
    if ! curl -sL "$zip_url" -o "$tmpdir/module.zip"; then
        echo "ERROR: Failed to download module '$name' from $zip_url" >&2
        rm -rf "$tmpdir"
        return 1
    fi

    # Record existing module directories before extraction
    existing_dirs=$(find "$modules_dir" -maxdepth 1 -mindepth 1 -type d -exec basename {} \; 2>/dev/null | sort)

    # Extract zip to the modules directory
    if ! unzip -oq "$tmpdir/module.zip" -d "$modules_dir"; then
        echo "ERROR: Failed to extract module zip for '$name'" >&2
        rm -rf "$tmpdir"
        return 1
    fi
    rm -rf "$tmpdir"

    # Find the newly extracted directory (directories not present before extraction)
    new_dir=""
    for dir in "$modules_dir"/*/; do
        [ -d "$dir" ] || continue
        dir_name=$(basename "$dir")
        if ! echo "$existing_dirs" | grep -qx "$dir_name"; then
            if [ -n "$new_dir" ]; then
                echo "WARNING: Multiple new directories found after extraction; using '$new_dir', ignoring '$dir_name'" >&2
            else
                new_dir="$dir_name"
            fi
        fi
    done

    # Rename extracted directory to the expected module name if needed
    if [ -n "$new_dir" ] && [ "$new_dir" != "$name" ]; then
        echo "Renaming module directory from '$new_dir' to '$name'..."
        mv "$modules_dir/$new_dir" "$modules_dir/$name"
    elif [ -z "$new_dir" ] && [ ! -d "$modules_dir/$name" ]; then
        echo "ERROR: Could not find extracted module directory for '$name'" >&2
        return 1
    fi

    # Run composer install if the module has PHP dependencies
    if [ -f "$modules_dir/$name/composer.json" ]; then
        echo "Running composer install for module '$name'..."
        if ! composer install --no-dev --no-scripts --optimize-autoloader --no-interaction --working-dir="$modules_dir/$name"; then
            echo "ERROR: composer install failed for module '$name'" >&2
            return 1
        fi
    fi

    # Install the module via omeka-s-cli
    echo "Installing module '$name' via omeka-s-cli..."
    if omeka-s-cli module:install "$name"; then
        echo "Module installed successfully: $name"
    else
        echo "ERROR: Failed to install module '$name' via omeka-s-cli" >&2
        return 1
    fi
}

# install items from names or "name: url" pairs
install_items_from_names() {
    local kind="$1"
    local env_var="$2"
    local items name url

    eval "items=\${$env_var:-}"
    [ -z "$items" ] && echo "No $kind to install. Skipping." && return

    printf '%s\n' "$items" | while IFS= read -r line; do
        # Trim leading/trailing whitespace and skip empty lines
        line=$(echo "$line" | sed 's/^[[:space:]]*//;s/[[:space:]]*$//')
        [ -z "$line" ] && continue

        # Check for "name: url" format (line contains ": http")
        if echo "$line" | grep -q ": http"; then
            name=$(echo "$line" | sed 's/:[[:space:]]*http.*//' | sed 's/^[[:space:]]*//;s/[[:space:]]*$//')
            url=$(echo "$line" | sed 's/^[^:]*:[[:space:]]*//')
            echo "Processing $kind from URL: $name ($url)..."
            if [ "$kind" = "modules" ]; then
                install_module_from_url "$name" "$url"
            fi
        else
            # Simple name - use omeka-s-cli download
            name="$line"
            echo "Processing $name..."
            if omeka-s-cli "${kind%s}:download" "$name"; then
                if [ "$kind" = "modules" ]; then
                    if omeka-s-cli "${kind%s}:install" "$name"; then
                        echo "$kind installed successfully: $name"
                    else
                        echo "ERROR: Failed to install $kind: $name" >&2
                    fi
                fi
            else
                echo "ERROR: Failed to download $kind: $name" >&2
            fi
        fi
    done
}


# Ensure a module is present (download+install if missing).
ensure_module() {
    local name="$1"
    if omeka-s-cli module:list | awk '{print $2}' | grep -qx "$name"; then
        echo "Module already installed: $name"
        return 0
    fi
    echo "Installing module: $name"
    omeka-s-cli module:download "$name" && omeka-s-cli module:install "$name"
}

# Automatically download and install modules
echo "Checking for modules to install..."
echo "OMEKA_MODULES value: '${OMEKA_MODULES:-<not set>}'"

install_items_from_names "modules" "OMEKA_MODULES"

chown -R www-data:www-data /var/www/html/volume/modules

# Install Omeka S only if required environment variables are set and not empty
if [ -n "${OMEKA_ADMIN_EMAIL:-}" ] && [ -n "${OMEKA_ADMIN_NAME:-}" ] && \
   [ -n "${OMEKA_ADMIN_PASSWORD:-}" ] && [ -n "${OMEKA_SITE_TITLE:-}" ]; then
  echo "[Entrypoint] Installing Omeka S via CLI..."

  # If MYSQL_HOST is set, check the availability of the database
#   if [ -n "$MYSQL_HOST" ]; then
#       check_db_availability "$MYSQL_HOST" 3306
#   fi

  CMD="php install_cli.php \
    --email=\"$OMEKA_ADMIN_EMAIL\" \
    --name=\"$OMEKA_ADMIN_NAME\" \
    --password=\"$OMEKA_ADMIN_PASSWORD\" \
    --title=\"$OMEKA_SITE_TITLE\""

  if [ -n "${OMEKA_TIMEZONE:-}" ]; then
    CMD="$CMD --timezone=\"$OMEKA_TIMEZONE\""
  fi

  if [ -n "${OMEKA_LOCALE:-}" ]; then
    CMD="$CMD --locale=\"$OMEKA_LOCALE\""
  fi

  eval "$CMD"
else
  echo "[Entrypoint] Skipping Omeka S install: missing required environment variables (OMEKA_ADMIN_EMAIL, OMEKA_ADMIN_NAME, OMEKA_ADMIN_PASSWORD, OMEKA_SITE_TITLE)"
fi

# Run the original Docker PHP entrypoint (ref. file https://github.com/docker-library/php/blob/master/8.2/bookworm/apache/docker-php-entrypoint)
# first argument is `-f` or another option
if [ "${1#-}" != "$1" ]; then
	set -- apache2-foreground "$@"
fi

exec "$@"
